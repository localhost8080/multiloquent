{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Rose",
  "settings": {
    "color": {
      "palette": [
        { "color": "#be185d", "name": "Primary",        "slug": "primary"       },
        { "color": "#9d174d", "name": "Primary Dark",   "slug": "primary-dark"  },
        { "color": "#f9a8d4", "name": "Primary Light",  "slug": "primary-light" },
        { "color": "#7c3aed", "name": "Secondary",      "slug": "secondary"     },
        { "color": "#ea580c", "name": "Accent",         "slug": "accent"        },
        { "color": "#dc2626", "name": "Danger",         "slug": "danger"        },
        { "color": "#ffffff", "name": "Base",           "slug": "base"          },
        { "color": "#1f0a14", "name": "Contrast",       "slug": "contrast"      },
        { "color": "#9d8fa0", "name": "Muted",          "slug": "muted"         },
        { "color": "#fdf2f8", "name": "Surface",        "slug": "surface"       },
        { "color": "#fce7f3", "name": "Surface Alt",    "slug": "surface-alt"   },
        { "color": "#fbcfe8", "name": "Border",         "slug": "border"        }
      ],
      "gradients": [
        {
          "gradient": "linear-gradient(135deg, #be185d 0%, #7c3aed 100%)",
          "name": "Primary to Secondary",
          "slug": "primary-to-secondary"
        },
        {
          "gradient": "linear-gradient(135deg, #be185d 0%, #f9a8d4 100%)",
          "name": "Primary Fade",
          "slug": "primary-fade"
        },
        {
          "gradient": "linear-gradient(180deg, #fdf2f8 0%, #ffffff 100%)",
          "name": "Surface to Base",
          "slug": "surface-to-base"
        },
        {
          "gradient": "linear-gradient(135deg, #1f0a14 0%, #be185d 100%)",
          "name": "Dark to Primary",
          "slug": "dark-to-primary"
        }
      ],
      "duotone": [
        {
          "colors": [ "#be185d", "#ffffff" ],
          "name": "Primary and White",
          "slug": "primary-and-white"
        },
        {
          "colors": [ "#1f0a14", "#f9a8d4" ],
          "name": "Contrast and Primary",
          "slug": "contrast-and-primary"
        }
      ]
    }
  },
  "styles": {
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--primary-dark)" } }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        ":hover": {
          "color": { "background": "var(--wp--preset--color--primary-dark)" }
        }
      }
    },
    "blocks": {
      "core/pullquote": {
        "border": { "color": "var(--wp--preset--color--primary)" }
      },
      "core/quote": {
        "border": { "color": "var(--wp--preset--color--primary)" }
      }
    }
  }
}
