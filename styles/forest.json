{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Forest",
  "settings": {
    "color": {
      "palette": [
        { "color": "#15803d", "name": "Primary",        "slug": "primary"       },
        { "color": "#166534", "name": "Primary Dark",   "slug": "primary-dark"  },
        { "color": "#4ade80", "name": "Primary Light",  "slug": "primary-light" },
        { "color": "#0369a1", "name": "Secondary",      "slug": "secondary"     },
        { "color": "#b45309", "name": "Accent",         "slug": "accent"        },
        { "color": "#dc2626", "name": "Danger",         "slug": "danger"        },
        { "color": "#ffffff", "name": "Base",           "slug": "base"          },
        { "color": "#1c2b1a", "name": "Contrast",       "slug": "contrast"      },
        { "color": "#6b7280", "name": "Muted",          "slug": "muted"         },
        { "color": "#f0fdf4", "name": "Surface",        "slug": "surface"       },
        { "color": "#dcfce7", "name": "Surface Alt",    "slug": "surface-alt"   },
        { "color": "#bbf7d0", "name": "Border",         "slug": "border"        }
      ],
      "gradients": [
        {
          "gradient": "linear-gradient(135deg, #15803d 0%, #0369a1 100%)",
          "name": "Primary to Secondary",
          "slug": "primary-to-secondary"
        },
        {
          "gradient": "linear-gradient(135deg, #15803d 0%, #4ade80 100%)",
          "name": "Primary Fade",
          "slug": "primary-fade"
        },
        {
          "gradient": "linear-gradient(180deg, #f0fdf4 0%, #ffffff 100%)",
          "name": "Surface to Base",
          "slug": "surface-to-base"
        },
        {
          "gradient": "linear-gradient(135deg, #1c2b1a 0%, #15803d 100%)",
          "name": "Dark to Primary",
          "slug": "dark-to-primary"
        }
      ],
      "duotone": [
        {
          "colors": [ "#15803d", "#ffffff" ],
          "name": "Primary and White",
          "slug": "primary-and-white"
        },
        {
          "colors": [ "#1c2b1a", "#4ade80" ],
          "name": "Contrast and Primary",
          "slug": "contrast-and-primary"
        }
      ]
    }
  },
  "styles": {
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--primary-dark)" } }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        ":hover": {
          "color": { "background": "var(--wp--preset--color--primary-dark)" }
        }
      }
    },
    "blocks": {
      "core/pullquote": {
        "border": { "color": "var(--wp--preset--color--primary)" }
      },
      "core/quote": {
        "border": { "color": "var(--wp--preset--color--primary)" }
      }
    }
  }
}
