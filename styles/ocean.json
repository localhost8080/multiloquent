{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Ocean",
  "settings": {
    "color": {
      "palette": [
        { "color": "#0891b2", "name": "Primary",        "slug": "primary"       },
        { "color": "#0e7490", "name": "Primary Dark",   "slug": "primary-dark"  },
        { "color": "#22d3ee", "name": "Primary Light",  "slug": "primary-light" },
        { "color": "#0d9488", "name": "Secondary",      "slug": "secondary"     },
        { "color": "#f59e0b", "name": "Accent",         "slug": "accent"        },
        { "color": "#dc2626", "name": "Danger",         "slug": "danger"        },
        { "color": "#ffffff", "name": "Base",           "slug": "base"          },
        { "color": "#0c1a2e", "name": "Contrast",       "slug": "contrast"      },
        { "color": "#64748b", "name": "Muted",          "slug": "muted"         },
        { "color": "#f0f9ff", "name": "Surface",        "slug": "surface"       },
        { "color": "#e0f2fe", "name": "Surface Alt",    "slug": "surface-alt"   },
        { "color": "#bae6fd", "name": "Border",         "slug": "border"        }
      ],
      "gradients": [
        {
          "gradient": "linear-gradient(135deg, #0891b2 0%, #0d9488 100%)",
          "name": "Primary to Secondary",
          "slug": "primary-to-secondary"
        },
        {
          "gradient": "linear-gradient(135deg, #0891b2 0%, #22d3ee 100%)",
          "name": "Primary Fade",
          "slug": "primary-fade"
        },
        {
          "gradient": "linear-gradient(180deg, #f0f9ff 0%, #ffffff 100%)",
          "name": "Surface to Base",
          "slug": "surface-to-base"
        },
        {
          "gradient": "linear-gradient(135deg, #0c1a2e 0%, #0891b2 100%)",
          "name": "Dark to Primary",
          "slug": "dark-to-primary"
        }
      ],
      "duotone": [
        {
          "colors": [ "#0891b2", "#ffffff" ],
          "name": "Primary and White",
          "slug": "primary-and-white"
        },
        {
          "colors": [ "#0c1a2e", "#22d3ee" ],
          "name": "Contrast and Primary",
          "slug": "contrast-and-primary"
        }
      ]
    }
  },
  "styles": {
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--primary-dark)" } }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        ":hover": {
          "color": { "background": "var(--wp--preset--color--primary-dark)" }
        }
      }
    },
    "blocks": {
      "core/pullquote": {
        "border": { "color": "var(--wp--preset--color--primary)" }
      },
      "core/quote": {
        "border": { "color": "var(--wp--preset--color--primary)" }
      }
    }
  }
}
