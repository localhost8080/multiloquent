{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,

    "color": {
      "custom": true,
      "customDuotone": true,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        { "color": "#1d4ed8", "name": "Primary",        "slug": "primary"       },
        { "color": "#1e40af", "name": "Primary Dark",   "slug": "primary-dark"  },
        { "color": "#3b82f6", "name": "Primary Light",  "slug": "primary-light" },
        { "color": "#16a34a", "name": "Secondary",      "slug": "secondary"     },
        { "color": "#d97706", "name": "Accent",         "slug": "accent"        },
        { "color": "#dc2626", "name": "Danger",         "slug": "danger"        },
        { "color": "#ffffff", "name": "Base",           "slug": "base"          },
        { "color": "#111827", "name": "Contrast",       "slug": "contrast"      },
        { "color": "#6b7280", "name": "Muted",          "slug": "muted"         },
        { "color": "#f9fafb", "name": "Surface",        "slug": "surface"       },
        { "color": "#f3f4f6", "name": "Surface Alt",    "slug": "surface-alt"   },
        { "color": "#e5e7eb", "name": "Border",         "slug": "border"        }
      ],
      "gradients": [
        {
          "gradient": "linear-gradient(135deg, #1d4ed8 0%, #16a34a 100%)",
          "name": "Primary to Secondary",
          "slug": "primary-to-secondary"
        },
        {
          "gradient": "linear-gradient(135deg, #1d4ed8 0%, #3b82f6 100%)",
          "name": "Primary Fade",
          "slug": "primary-fade"
        },
        {
          "gradient": "linear-gradient(180deg, #f9fafb 0%, #ffffff 100%)",
          "name": "Surface to Base",
          "slug": "surface-to-base"
        },
        {
          "gradient": "linear-gradient(135deg, #111827 0%, #1e40af 100%)",
          "name": "Dark to Primary",
          "slug": "dark-to-primary"
        }
      ],
      "duotone": [
        {
          "colors": [ "#1d4ed8", "#ffffff" ],
          "name": "Primary and White",
          "slug": "primary-and-white"
        },
        {
          "colors": [ "#111827", "#3b82f6" ],
          "name": "Contrast and Primary",
          "slug": "contrast-and-primary"
        }
      ]
    },

    "typography": {
      "customFontSize": true,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
          "name": "System Sans-Serif",
          "slug": "system"
        },
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "name": "Serif",
          "slug": "serif"
        },
        {
          "fontFamily": "'Fira Code', 'Fira Mono', 'Cascadia Code', Consolas, monospace",
          "name": "Monospace",
          "slug": "mono"
        }
      ],
      "fontSizes": [
        {
          "fluid": false,
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "fluid": false,
          "name": "Medium",
          "size": "1rem",
          "slug": "medium"
        },
        {
          "fluid": { "min": "1.0625rem", "max": "1.125rem" },
          "name": "Large",
          "size": "1.0625rem",
          "slug": "large"
        },
        {
          "fluid": { "min": "1.25rem", "max": "1.5rem" },
          "name": "X-Large",
          "size": "1.5rem",
          "slug": "x-large"
        },
        {
          "fluid": { "min": "1.5rem", "max": "2.25rem" },
          "name": "2X-Large",
          "size": "2.25rem",
          "slug": "xx-large"
        },
        {
          "fluid": { "min": "2rem", "max": "3rem" },
          "name": "3X-Large",
          "size": "3rem",
          "slug": "xxx-large"
        }
      ]
    },

    "spacing": {
      "customSpacingSize": true,
      "units": [ "px", "%", "em", "rem", "vw", "vh" ],
      "spacingSizes": [
        { "name": "1", "size": "0.25rem",  "slug": "10" },
        { "name": "2", "size": "0.5rem",   "slug": "20" },
        { "name": "3", "size": "0.75rem",  "slug": "30" },
        { "name": "4", "size": "1rem",     "slug": "40" },
        { "name": "5", "size": "1.5rem",   "slug": "50" },
        { "name": "6", "size": "2rem",     "slug": "60" },
        { "name": "7", "size": "3rem",     "slug": "70" },
        { "name": "8", "size": "4.5rem",   "slug": "80" },
        { "name": "9", "size": "6rem",     "slug": "90" }
      ]
    },

    "layout": {
      "contentSize": "780px",
      "wideSize": "1200px"
    },

    "dimensions": {
      "aspectRatios": [
        { "name": "Square",       "ratio": "1",    "slug": "square"        },
        { "name": "Standard",     "ratio": "4/3",  "slug": "4-3"           },
        { "name": "Portrait",     "ratio": "3/4",  "slug": "3-4"           },
        { "name": "Classic",      "ratio": "3/2",  "slug": "3-2"           },
        { "name": "Wide",         "ratio": "16/9", "slug": "16-9"          },
        { "name": "Ultra-wide",   "ratio": "21/9", "slug": "21-9"          }
      ],
      "minHeight": true
    },

    "position": {
      "sticky": true
    },

    "shadow": {
      "presets": [
        { "name": "Natural", "shadow": "0 4px 8px rgba(0,0,0,.08)", "slug": "natural"  },
        { "name": "Deep",    "shadow": "0 8px 24px rgba(0,0,0,.14)", "slug": "deep"    },
        { "name": "Sharp",   "shadow": "2px 2px 0 rgba(0,0,0,.1)",  "slug": "sharp"   }
      ]
    },

    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },

    "blocks": {
      "core/navigation": {
        "typography": {
          "fontSize": true,
          "lineHeight": true
        }
      },
      "core/post-featured-image": {
        "dimensions": { "aspectRatio": true }
      }
    }
  },

  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.7"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--50)"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--system)",
          "fontWeight": "700",
          "lineHeight": "1.25"
        }
      },
      "h1": {
        "typography": { "fontSize": "var(--wp--preset--font-size--xxx-large)" }
      },
      "h2": {
        "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" }
      },
      "h3": {
        "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" }
      },
      "h4": {
        "typography": { "fontSize": "var(--wp--preset--font-size--large)" }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--primary-dark)" } },
        "typography": { "textDecoration": "underline" }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": { "radius": "0.375rem" },
        "spacing": { "padding": { "top": "0.5rem", "bottom": "0.5rem", "left": "1.25rem", "right": "1.25rem" } },
        ":hover": {
          "color": { "background": "var(--wp--preset--color--primary-dark)" }
        }
      }
    },
    "blocks": {
      "core/separator": {
        "color": { "text": "var(--wp--preset--color--border)" },
        "border": { "color": "var(--wp--preset--color--border)" }
      },
      "core/pullquote": {
        "border": {
          "color": "var(--wp--preset--color--primary)",
          "style": "solid",
          "width": "0 0 0 4px"
        },
        "color": { "text": "var(--wp--preset--color--muted)" },
        "typography": { "fontStyle": "italic" }
      },
      "core/code": {
        "color": { "background": "var(--wp--preset--color--surface-alt)" },
        "border": { "radius": "0.375rem" },
        "spacing": { "padding": { "top": "1rem", "bottom": "1rem", "left": "1rem", "right": "1rem" } },
        "typography": { "fontFamily": "var(--wp--preset--font-family--mono)" }
      },
      "core/quote": {
        "border": {
          "color": "var(--wp--preset--color--primary)",
          "style": "solid",
          "width": "0 0 0 4px"
        },
        "spacing": { "padding": { "left": "1rem" } },
        "typography": { "fontStyle": "italic" }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "fontWeight": "700"
        }
      }
    }
  },

  "customTemplates": [
    {
      "name": "page",
      "postTypes": [ "page" ],
      "title": "Default Page"
    },
    {
      "name": "template-full-width",
      "postTypes": [ "page", "post" ],
      "title": "Full Width"
    },
    {
      "name": "template-full-width-no-header-single",
      "postTypes": [ "page", "post" ],
      "title": "Full Width (No Header)"
    }
  ],

  "templateParts": [
    { "area": "header", "name": "header", "title": "Header" },
    { "area": "footer", "name": "footer", "title": "Footer" }
  ]
}
